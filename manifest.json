{
  "manifest_version": 3,
  "name": "GBM L1 Ticket Entry",
  "version": "1.0.0",
  "description": "Fast ticket entry tool for GBM L1 support team",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": ["https://api.openai.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
